{
  "$schema": "https://biomejs.dev/schemas/2.3.6/schema.json",
  "root": false,
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "a11y": "off",
      "complexity": "off",
      "correctness": "off",
      "nursery": "off",
      "performance": "off",
      "security": "off",
      "style": "off",
      "suspicious": "off"
    }
  }
}
