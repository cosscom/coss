      "path": "registry/default/particles/p-drawer-7.tsx",
      "content": "import { Button } from \"@/registry/default/ui/button\";\r\nimport {\r\n  Drawer,\r\n  DrawerClose,\r\n  DrawerDescription,\r\n  DrawerFooter,\r\n  DrawerHeader,\r\n  DrawerPanel,\r\n  DrawerPopup,\r\n  DrawerTitle,\r\n  DrawerTrigger,\r\n} from \"@/registry/default/ui/drawer\";\r\n\r\nexport default function Particle() {\r\n  return (\r\n    <Drawer>\r\n      <DrawerTrigger render={<Button variant=\"outline\" />}>\r\n        Nested drawers\r\n      </DrawerTrigger>\r\n      <DrawerPopup showBar>\r\n        <DrawerHeader className=\"text-center\">\r\n          <DrawerTitle>First step</DrawerTitle>\r\n          <DrawerDescription>\r\n            This is the first step. Tap the button below to continue to the next\r\n            screen.\r\n          </DrawerDescription>\r\n        </DrawerHeader>\r\n        <DrawerFooter\r\n          className=\"justify-center sm:justify-center\"\r\n          variant=\"bare\"\r\n        >\r\n          <DrawerClose render={<Button variant=\"ghost\" />}>Cancel</DrawerClose>\r\n          <Drawer>\r\n            <DrawerTrigger render={<Button variant=\"outline\" />}>\r\n              Continue\r\n            </DrawerTrigger>\r\n            <DrawerPopup showBar>\r\n              <DrawerHeader className=\"text-center\">\r\n                <DrawerTitle>Second step</DrawerTitle>\r\n                <DrawerDescription>\r\n                  You&apos;ve reached the second step. Tap the button below to\r\n                  continue to the next screen.\r\n                </DrawerDescription>\r\n              </DrawerHeader>\r\n              <DrawerPanel>\r\n                <div className=\"flex justify-center\">\r\n                  <div className=\"size-48 shrink-0 rounded-xl border bg-muted\" />\r\n                </div>\r\n              </DrawerPanel>\r\n              <DrawerFooter\r\n                className=\"justify-center sm:justify-center\"\r\n                variant=\"bare\"\r\n              >\r\n                <DrawerClose render={<Button variant=\"ghost\" />}>\r\n                  Back\r\n                </DrawerClose>\r\n                <Drawer>\r\n                  <DrawerTrigger render={<Button variant=\"outline\" />}>\r\n                    Continue\r\n                  </DrawerTrigger>\r\n                  <DrawerPopup showBar>\r\n                    <DrawerHeader className=\"text-center\">\r\n                      <DrawerTitle>Third step</DrawerTitle>\r\n                      <DrawerDescription>\r\n                        You&apos;ve reached the final step. You can close this\r\n                        drawer or go back.\r\n                      </DrawerDescription>\r\n                    </DrawerHeader>\r\n                    <DrawerPanel>\r\n                      <div className=\"flex justify-center\">\r\n                        <div className=\"size-32 shrink-0 rounded-full border bg-muted\" />\r\n                      </div>\r\n                    </DrawerPanel>\r\n                  </DrawerPopup>\r\n                </Drawer>\r\n              </DrawerFooter>\r\n            </DrawerPopup>\r\n          </Drawer>\r\n        </DrawerFooter>\r\n      </DrawerPopup>\r\n    </Drawer>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
