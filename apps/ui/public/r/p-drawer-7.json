{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "p-drawer-7",
  "type": "registry:block",
  "description": "Nested drawers",
  "registryDependencies": [
    "@coss/button",
    "@coss/drawer",
    "@coss/field",
    "@coss/input"
  ],
  "files": [
    {
      "path": "registry/default/particles/p-drawer-7.tsx",
      "content": "import { Button } from \"@/registry/default/ui/button\";\nimport {\n  Drawer,\n  DrawerClose,\n  DrawerDescription,\n  DrawerFooter,\n  DrawerHeader,\n  DrawerPanel,\n  DrawerPopup,\n  DrawerTitle,\n  DrawerTrigger,\n} from \"@/registry/default/ui/drawer\";\n\nexport default function Particle() {\n  return (\n    <Drawer position=\"bottom\">\n      <DrawerTrigger render={<Button variant=\"outline\" />}>\n        Open drawer\n      </DrawerTrigger>\n      <DrawerPopup showBar showCloseButton={false} variant=\"inset\">\n        <DrawerHeader className=\"items-center\">\n          <DrawerTitle>Account</DrawerTitle>\n          <DrawerDescription>\n            Nested drawers stack on top of each other. Try opening the one\n            below.\n          </DrawerDescription>\n        </DrawerHeader>\n        <DrawerPanel>\n          <div aria-hidden className=\"grid gap-3\">\n            <div className=\"h-12 rounded-xl border bg-muted/50\" />\n            <div className=\"h-12 rounded-xl border bg-muted/50\" />\n            <div className=\"h-12 rounded-xl border bg-muted/50\" />\n            <div className=\"h-12 rounded-xl border bg-muted/50\" />\n          </div>\n        </DrawerPanel>\n        <DrawerFooter variant=\"bare\">\n          <Drawer position=\"bottom\">\n            <DrawerTrigger render={<Button variant=\"outline\" />}>\n              Security settings\n            </DrawerTrigger>\n            <DrawerPopup showBar showCloseButton={false} variant=\"inset\">\n              <DrawerHeader className=\"items-center\">\n                <DrawerTitle>Security</DrawerTitle>\n                <DrawerDescription>\n                  Review sign-in activity and update your security preferences.\n                </DrawerDescription>\n              </DrawerHeader>\n              <DrawerPanel>\n                <ul className=\"list-disc pl-5 text-sm\">\n                  <li>Passkeys enabled</li>\n                  <li>2FA via authenticator app</li>\n                  <li>3 signed-in devices</li>\n                </ul>\n              </DrawerPanel>\n              <DrawerFooter variant=\"bare\">\n                <Drawer position=\"bottom\">\n                  <DrawerTrigger render={<Button variant=\"outline\" />}>\n                    Privacy settings\n                  </DrawerTrigger>\n                  <DrawerPopup showBar showCloseButton={false} variant=\"inset\">\n                    <DrawerHeader className=\"items-center\">\n                      <DrawerTitle>Privacy</DrawerTitle>\n                      <DrawerDescription>\n                        Manage your data sharing and visibility preferences.\n                      </DrawerDescription>\n                    </DrawerHeader>\n                    <DrawerPanel>\n                      <ul className=\"list-disc pl-5 text-sm\">\n                        <li>Profile visible to contacts only</li>\n                        <li>Activity status hidden</li>\n                        <li>Data export available</li>\n                      </ul>\n                    </DrawerPanel>\n                    <DrawerFooter variant=\"bare\">\n                      <Drawer position=\"bottom\">\n                        <DrawerTrigger render={<Button variant=\"outline\" />}>\n                          Notifications\n                        </DrawerTrigger>\n                        <DrawerPopup\n                          showBar\n                          showCloseButton={false}\n                          variant=\"inset\"\n                        >\n                          <DrawerHeader className=\"items-center\">\n                            <DrawerTitle>Notifications</DrawerTitle>\n                            <DrawerDescription>\n                              Choose how and when you want to be notified.\n                            </DrawerDescription>\n                          </DrawerHeader>\n                          <DrawerFooter variant=\"bare\">\n                            <DrawerClose render={<Button variant=\"outline\" />}>\n                              Close\n                            </DrawerClose>\n                          </DrawerFooter>\n                        </DrawerPopup>\n                      </Drawer>\n                    </DrawerFooter>\n                  </DrawerPopup>\n                </Drawer>\n              </DrawerFooter>\n            </DrawerPopup>\n          </Drawer>\n        </DrawerFooter>\n      </DrawerPopup>\n    </Drawer>\n  );\n}\n",
      "type": "registry:block"
    }
  ],
  "categories": [
    "drawer"
  ]
}