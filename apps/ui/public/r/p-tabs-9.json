{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "p-tabs-9",
  "description": "Tabs with underline and icon on top",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "@coss/tabs"
  ],
  "files": [
    {
      "path": "registry/default/particles/p-tabs-9.tsx",
      "content": "import { BoxIcon, HouseIcon, PanelsTopLeftIcon } from \"lucide-react\";\r\nimport { Tabs, TabsList, TabsPanel, TabsTab } from \"@/registry/default/ui/tabs\";\r\n\r\nexport default function Particle() {\r\n  return (\r\n    <Tabs className=\"items-center\" defaultValue=\"tab-1\">\r\n      <div className=\"border-b\">\r\n        <TabsList variant=\"underline\">\r\n          <TabsTab\r\n            className=\"h-auto! flex-col gap-1.5 py-[calc(--spacing(2)-1px)]\"\r\n            value=\"tab-1\"\r\n          >\r\n            <HouseIcon aria-hidden=\"true\" className=\"opacity-60\" size={16} />\r\n            Overview\r\n          </TabsTab>\r\n          <TabsTab\r\n            className=\"h-auto! flex-col gap-1.5 py-[calc(--spacing(2)-1px)]\"\r\n            value=\"tab-2\"\r\n          >\r\n            <PanelsTopLeftIcon\r\n              aria-hidden=\"true\"\r\n              className=\"opacity-60\"\r\n              size={16}\r\n            />\r\n            Projects\r\n          </TabsTab>\r\n          <TabsTab\r\n            className=\"h-auto! flex-col gap-1.5 py-[calc(--spacing(2.5)-1px)]\"\r\n            value=\"tab-3\"\r\n          >\r\n            <BoxIcon aria-hidden=\"true\" className=\"opacity-60\" size={16} />\r\n            Packages\r\n          </TabsTab>\r\n        </TabsList>\r\n      </div>\r\n      <TabsPanel value=\"tab-1\">\r\n        <p className=\"p-4 text-center text-muted-foreground text-xs\">\r\n          Overview content\r\n        </p>\r\n      </TabsPanel>\r\n      <TabsPanel value=\"tab-2\">\r\n        <p className=\"p-4 text-center text-muted-foreground text-xs\">\r\n          Projects content\r\n        </p>\r\n      </TabsPanel>\r\n      <TabsPanel value=\"tab-3\">\r\n        <p className=\"p-4 text-center text-muted-foreground text-xs\">\r\n          Packages content\r\n        </p>\r\n      </TabsPanel>\r\n    </Tabs>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "categories": [
    "tabs"
  ],
  "type": "registry:block"
}