{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "p-tabs-12",
  "description": "Tabs with icon only and count badge",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "@coss/badge",
    "@coss/tabs"
  ],
  "files": [
    {
      "path": "registry/default/particles/p-tabs-12.tsx",
      "content": "import { HouseIcon, InboxIcon, SettingsIcon } from \"lucide-react\";\r\nimport { Badge } from \"@/registry/default/ui/badge\";\r\nimport { Tabs, TabsList, TabsPanel, TabsTab } from \"@/registry/default/ui/tabs\";\r\n\r\nexport default function Particle() {\r\n  return (\r\n    <Tabs className=\"items-center\" defaultValue=\"tab-1\">\r\n      <TabsList>\r\n        <TabsTab aria-label=\"Overview\" className=\"size-10!\" value=\"tab-1\">\r\n          <HouseIcon aria-hidden=\"true\" />\r\n        </TabsTab>\r\n        <TabsTab aria-label=\"Inbox\" className=\"size-10!\" value=\"tab-2\">\r\n          <InboxIcon aria-hidden=\"true\" />\r\n          <Badge\r\n            className=\"absolute end-0 top-0 rounded-full not-in-data-active:opacity-64\"\r\n            size=\"sm\"\r\n          >\r\n            5\r\n          </Badge>\r\n        </TabsTab>\r\n        <TabsTab aria-label=\"Settings\" className=\"size-10!\" value=\"tab-3\">\r\n          <SettingsIcon aria-hidden=\"true\" />\r\n        </TabsTab>\r\n      </TabsList>\r\n      <TabsPanel value=\"tab-1\">\r\n        <p className=\"p-4 text-center text-muted-foreground text-xs\">\r\n          Overview content\r\n        </p>\r\n      </TabsPanel>\r\n      <TabsPanel value=\"tab-2\">\r\n        <p className=\"p-4 text-center text-muted-foreground text-xs\">\r\n          Inbox content\r\n        </p>\r\n      </TabsPanel>\r\n      <TabsPanel value=\"tab-3\">\r\n        <p className=\"p-4 text-center text-muted-foreground text-xs\">\r\n          Settings content\r\n        </p>\r\n      </TabsPanel>\r\n    </Tabs>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "categories": [
    "tabs",
    "badge"
  ],
  "type": "registry:block"
}