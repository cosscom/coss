{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "p-tabs-13",
  "description": "Tabs with icon only and grouped tooltips",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "@coss/tabs",
    "@coss/tooltip"
  ],
  "files": [
    {
      "path": "registry/default/particles/p-tabs-13.tsx",
      "content": "import { HouseIcon, PanelsTopLeftIcon, SettingsIcon } from \"lucide-react\";\r\nimport { Tabs, TabsList, TabsPanel, TabsTab } from \"@/registry/default/ui/tabs\";\r\nimport {\r\n  Tooltip,\r\n  TooltipPopup,\r\n  TooltipProvider,\r\n  TooltipTrigger,\r\n} from \"@/registry/default/ui/tooltip\";\r\n\r\nexport default function Particle() {\r\n  return (\r\n    <TooltipProvider>\r\n      <Tabs className=\"items-center\" defaultValue=\"tab-1\">\r\n        <TabsList>\r\n          <Tooltip>\r\n            <TooltipTrigger\r\n              render={<TabsTab aria-label=\"Overview\" value=\"tab-1\" />}\r\n            >\r\n              <HouseIcon aria-hidden=\"true\" />\r\n            </TooltipTrigger>\r\n            <TooltipPopup>Overview</TooltipPopup>\r\n          </Tooltip>\r\n          <Tooltip>\r\n            <TooltipTrigger\r\n              render={<TabsTab aria-label=\"Projects\" value=\"tab-2\" />}\r\n            >\r\n              <PanelsTopLeftIcon aria-hidden=\"true\" />\r\n            </TooltipTrigger>\r\n            <TooltipPopup>Projects</TooltipPopup>\r\n          </Tooltip>\r\n          <Tooltip>\r\n            <TooltipTrigger\r\n              render={<TabsTab aria-label=\"Settings\" value=\"tab-3\" />}\r\n            >\r\n              <SettingsIcon aria-hidden=\"true\" />\r\n            </TooltipTrigger>\r\n            <TooltipPopup>Settings</TooltipPopup>\r\n          </Tooltip>\r\n        </TabsList>\r\n        <TabsPanel value=\"tab-1\">\r\n          <p className=\"p-4 text-center text-muted-foreground text-xs\">\r\n            Overview content\r\n          </p>\r\n        </TabsPanel>\r\n        <TabsPanel value=\"tab-2\">\r\n          <p className=\"p-4 text-center text-muted-foreground text-xs\">\r\n            Projects content\r\n          </p>\r\n        </TabsPanel>\r\n        <TabsPanel value=\"tab-3\">\r\n          <p className=\"p-4 text-center text-muted-foreground text-xs\">\r\n            Settings content\r\n          </p>\r\n        </TabsPanel>\r\n      </Tabs>\r\n    </TooltipProvider>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "categories": [
    "tabs",
    "tooltip"
  ],
  "type": "registry:block"
}