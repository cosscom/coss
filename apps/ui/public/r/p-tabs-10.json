      "path": "registry/default/particles/p-tabs-10.tsx",
      "content": "import { Badge } from \"@/registry/default/ui/badge\";\r\nimport { Tabs, TabsList, TabsPanel, TabsTab } from \"@/registry/default/ui/tabs\";\r\n\r\nexport default function Particle() {\r\n  return (\r\n    <Tabs defaultValue=\"tab-1\">\r\n      <TabsList>\r\n        <TabsTab value=\"tab-1\">\r\n          All\r\n          <Badge\r\n            className=\"not-in-data-active:text-muted-foreground\"\r\n            variant=\"outline\"\r\n          >\r\n            128\r\n          </Badge>\r\n        </TabsTab>\r\n        <TabsTab value=\"tab-2\">\r\n          Pending\r\n          <Badge\r\n            className=\"not-in-data-active:text-muted-foreground\"\r\n            variant=\"outline\"\r\n          >\r\n            8\r\n          </Badge>\r\n        </TabsTab>\r\n        <TabsTab value=\"tab-3\">\r\n          Completed\r\n          <Badge\r\n            className=\"not-in-data-active:text-muted-foreground\"\r\n            variant=\"outline\"\r\n          >\r\n            120\r\n          </Badge>\r\n        </TabsTab>\r\n      </TabsList>\r\n      <TabsPanel value=\"tab-1\">\r\n        <p className=\"p-4 text-center text-muted-foreground text-xs\">\r\n          All items content\r\n        </p>\r\n      </TabsPanel>\r\n      <TabsPanel value=\"tab-2\">\r\n        <p className=\"p-4 text-center text-muted-foreground text-xs\">\r\n          Pending items content\r\n        </p>\r\n      </TabsPanel>\r\n      <TabsPanel value=\"tab-3\">\r\n        <p className=\"p-4 text-center text-muted-foreground text-xs\">\r\n          Completed items content\r\n        </p>\r\n      </TabsPanel>\r\n    </Tabs>\r\n  );\r\n}\r\n",
      "type": "registry:block"
    }
  ],
  "categories": [
