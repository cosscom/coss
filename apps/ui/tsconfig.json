{
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./*"],
      "@/lib/booker/actions": [
        "./registry/default/atoms/lib/booker/actions.ts"
      ],
      "@/lib/booker/*": ["./registry/default/atoms/lib/booker/*"],
      "@/lib/cal-api/*": ["./registry/default/lib/cal-api/*"],
      "@coss/ui/*": ["../../packages/ui/src/*"],
      "@source/*": ["./.source/*"]
    }
  },
  "exclude": ["node_modules"],
  "extends": "@coss/typescript-config/nextjs.json",
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ]
}
